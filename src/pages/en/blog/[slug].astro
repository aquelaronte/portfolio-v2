---
import ArticlePage from "@/components/pages/article/article-page.astro";
import { getArticleSlug } from "@/lib/infrastructure/articles/fetch";
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";

export const getStaticPaths = (async () => {
  const articles = await getCollection("blog", ({ id }) =>
    id.startsWith("en/"),
  );

  return articles.map((article) => ({
    params: { slug: getArticleSlug(article) },
    props: { article: article },
  }));
}) satisfies GetStaticPaths;

const { article } = Astro.props;
---

<ArticlePage article={article} />
