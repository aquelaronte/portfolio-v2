---
import Badge from "../atoms/badge.astro";
import { formatDate } from "@/lib/helpers/format-date";
import {
  getArticleLang,
  getArticleSlug,
  type Article,
} from "@/lib/infrastructure/articles/fetch";
import { useTranslations } from "@/lib/i18n/ui";
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  article: Article;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;

const lang = getArticleLang(article);
const t = useTranslations(lang);
const href = getRelativeLocaleUrl(lang, `blog/${getArticleSlug(article)}`);
---

<a
  href={href}
  class:list={[
    "group border-foreground/10 bg-foreground/5 hover:border-primary/40 hover:shadow-primary/30 mb-6.5 grid cursor-pointer overflow-hidden rounded-xl border transition-all duration-300 hover:shadow-[0_0_30px_-5px]",
    featured ? "grid-cols-1 md:grid-cols-[1.05fr_1fr]" : "grid-cols-1",
  ]}
>
  <Image
    src={article.data.cover.url}
    alt={article.data.cover.alt}
    transition:name={`article-cover-${article.id}`}
    class:list={[
      "border-foreground/10 relative w-full border-b object-cover",
      featured
        ? "max-h-56 min-h-56 md:h-full md:max-h-none md:min-h-85 md:border-r md:border-b-0"
        : "max-h-56 min-h-56",
    ]}
  />
  <div class="flex flex-col justify-center px-6 py-7 sm:px-9 sm:py-9.5">
    <div
      class="mb-4 flex flex-wrap gap-2"
      transition:name={`article-tags-${article.id}`}
    >
      {article.data.tags.map((tag, i) => <Badge>{tag}</Badge>)}
    </div>
    <h2
      transition:name={`article-title-${article.id}`}
      class:list={[
        "text-foreground mb-3.5 font-mono! leading-[1.18] font-semibold tracking-tight",
        featured ? "text-2xl" : "text-lg",
      ]}
    >
      {article.data.title}
    </h2>
    <p
      transition:name={`article-description-${article.id}`}
      class:list={[
        "text-foreground/80 mb-5.5 leading-[1.65]",
        featured ? "text-sm" : "line-clamp-3 text-xs",
      ]}
    >
      {article.data.description}
    </p>

    <div
      class="text-foreground/70 mt-auto flex items-center gap-3.5 text-xs"
      transition:name={`article-meta-${article.id}`}
    >
      <!-- Date -->
      <span>{formatDate(article.data.date)}</span>

      <span>.</span>

      <!-- Estimated reading time -->
      <span>{article.data.estimatedReadingTime} min</span>

      <span class="flex-1"></span>

      <span class="text-primary flex items-center gap-1 group-hover:underline"
        >{t("card.read")} <span aria-hidden="true">&rarr;</span></span
      >
    </div>
  </div>
</a>
