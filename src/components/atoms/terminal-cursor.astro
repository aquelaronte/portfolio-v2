---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={["terminal-cursor text-primary font-mono", className]}>_</span
>

<style>
  .terminal-cursor {
    animation: terminal-blink 1s step-end infinite;
  }

  @keyframes terminal-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
