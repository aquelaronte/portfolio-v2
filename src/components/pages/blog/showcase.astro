---
import Separator from "@/components/atoms/separator.astro";
import TerminalLine from "@/components/atoms/terminal-line.astro";
import { fetchAllArticles } from "@/lib/infrastructure/articles/fetch";
import ArticleCard from "@/components/molecules/article-card.astro";
import { getLang, useTranslations } from "@/lib/i18n/ui";

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const articles = await fetchAllArticles(lang);

const [featured, ...rest] = articles;
---

<Separator>
  <TerminalLine class="tracking-widest" command="ls -la">
    {t("showcase.recent")}
  </TerminalLine>
  <p slot="after" class="text-foreground/55 text-xs">
    {articles.length} {t("showcase.articles")}
  </p>
</Separator>
<ArticleCard article={featured} featured />

<div class="grid grid-cols-1 gap-x-6 sm:grid-cols-2 lg:grid-cols-3">
  {rest.map((article) => <ArticleCard article={article} />)}
</div>
