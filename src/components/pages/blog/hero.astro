---
import TerminalCursor from "@/components/atoms/terminal-cursor.astro";
import TerminalLine from "@/components/atoms/terminal-line.astro";
import { getLang, useTranslations } from "@/lib/i18n/ui";

const t = useTranslations(getLang(Astro.currentLocale));
---

<section class="pt-22 pb-14">
  <TerminalLine command="cat" class="pb-5.5"> ~/blog/README.md</TerminalLine>
  <h1 class="text-[clamp(72px,11vw,148px)] leading-[0.9] tracking-wide">
    {t("hero.title")}
  </h1>
  <p class="text-foreground/55 mt-5.5 max-w-155 text-sm leading-[1.7]">
    {t("hero.intro")} <TerminalCursor />
  </p>
</section>
