---
import Badge from "@/components/atoms/badge.astro";
import CodeBlock from "@/components/pages/article/code-block.astro";
import ArticleIndex from "@/components/pages/article/article-index.astro";
import { formatDate } from "@/lib/helpers/format-date";
import type { Article } from "@/lib/infrastructure/articles/fetch";
import type { MarkdownHeading } from "astro";
import { Image } from "astro:assets";
import { render } from "astro:content";

interface Props {
  article: Article;
  headings: MarkdownHeading[];
}

const { article, headings } = Astro.props;
const { Content } = await render(article);
---

<article>
  <div class="mb-5.5">
    <!-- Back button -->
    <a
      href="/blog"
      class="group hover:text-primary inline-block w-fit text-sm transition-colors"
    >
      <span
        aria-hidden="true"
        class="mr-2 inline-block transition-transform group-hover:-translate-x-0.5"
        >&larr;</span
      >

      <span><span class="text-primary">cd</span> ~/blog</span>
    </a>
  </div>

  <!-- tags -->
  <div
    class="mb-4.5 flex flex-row flex-wrap items-center gap-2"
    transition:name={`article-tags-${article.id}`}
  >
    {article.data.tags.map((tag) => <Badge>{tag}</Badge>)}
  </div>

  <h1
    class="article-title text-foreground mb-5 leading-[1.14] tracking-tight"
    transition:name={`article-title-${article.id}`}
  >
    {article.data.title}
  </h1>

  <!-- description -->
  <p
    class="text-foreground/60 mb-6 text-lg leading-[1.6]"
    transition:name={`article-description-${article.id}`}
  >
    {article.data.description}
  </p>

  <!-- metadata -->
  <div
    class="text-foreground/80 border-b-foreground/10 mb-9 flex items-center gap-4 border-b pb-6.5 text-xs"
    transition:name={`article-meta-${article.id}`}
  >
    <!-- Date -->
    <span>{formatDate(article.data.date)}</span>

    <span>.</span>

    <!-- Estimated reading time -->
    <span>{article.data.estimatedReadingTime} min</span>
  </div>

  <!-- cover -->
  <Image
    class="border-foreground/5 mb-10 flex w-full items-center justify-center rounded-2xl border"
    src={article.data.cover.url}
    alt={article.data.cover.alt}
    transition:name={`article-cover-${article.id}`}
  />

  <!-- Immersive mode: the index moves here, full width, right after the cover. -->
  <ArticleIndex headings={headings} variant="inline" />

  <div class="article-content">
    <Content components={{ pre: CodeBlock }} />
  </div>
</article>

<style>
  @reference "../../../styles/global.css";

  .article-content :global(*) {
    @apply text-foreground/70 text-base;
    line-height: 1.78;
  }

  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    @apply text-foreground font-mono! font-semibold;
    line-height: 1.14;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .article-content :global(h2) {
    font-size: 24px;
    margin-top: 46px;
    margin-bottom: 18px;
  }

  .article-content :global(h2)::before {
    @apply text-primary;
    content: "## ";
  }

  .article-content :global(h3) {
    font-size: 18px;
    margin-top: 46px;
    margin-bottom: 18px;
  }

  .article-content :global(h3)::before {
    @apply text-primary;
    content: "### ";
  }

  .article-content :global(p) {
    margin-bottom: 20px;
  }

  .article-content :global(blockquote) {
    @apply border-primary/40 bg-foreground/5 text-foreground/60;
    border-left: 3px solid;
    border-radius: 8px;
    margin: 24px 0;
    padding: 14px 18px;
    font-size: 14px;
    line-height: 1.7;
  }

  .article-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(blockquote strong) {
    @apply text-foreground/80;
  }

  .article-content :global(a) {
    @apply text-primary decoration-primary/40 underline underline-offset-4 transition-colors;
    text-decoration-thickness: 1px;
  }

  .article-content :global(a:hover) {
    @apply decoration-primary;
  }

  .article-content :global(:not(pre) > code) {
    @apply text-primary bg-foreground/5 border-foreground/10 rounded-md border font-mono!;
    padding: 2px 6px;
    font-size: 0.875em;
  }

  .article-content :global(pre) {
    @apply bg-foreground/5 border-foreground/10 rounded-xl border;
    margin: 24px 0;
    padding: 16px 18px;
    overflow-x: auto;
    line-height: 1.6;
  }

  .article-content :global(pre code) {
    @apply font-mono!;
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
  }

  /* --- Code block wrapper (top bar + copy button + line numbers) --- */
  .article-content :global(.code-block) {
    @apply border-foreground/10 overflow-hidden rounded-xl border;
    margin: 24px 0;
  }

  /* The wrapper now owns the frame; the inner <pre> sits flush under the bar. */
  .article-content :global(.code-block > pre) {
    margin: 0;
    border: none;
    border-radius: 0;
  }

  .article-content :global(.code-block__bar) {
    @apply bg-foreground/5 border-b-foreground/10 border-b font-mono!;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 14px;
    line-height: 1;
  }

  .article-content :global(.code-block__lang) {
    @apply text-foreground/45;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .article-content :global(.code-block__copy) {
    @apply text-foreground/45 hover:text-foreground/80 cursor-pointer transition-colors;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    font-size: 12px;
    font-family: inherit;
  }

  .article-content :global(.code-block__icon) {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .article-content :global(.code-block__icon--check) {
    @apply text-primary;
    display: none;
  }

  .article-content :global(.code-block__copy-text--done) {
    @apply text-primary;
    display: none;
  }

  .article-content :global(.code-block[data-copied] .code-block__icon--copy),
  .article-content
    :global(.code-block[data-copied] .code-block__copy-text--idle) {
    display: none;
  }

  .article-content :global(.code-block[data-copied] .code-block__icon--check),
  .article-content
    :global(.code-block[data-copied] .code-block__copy-text--done) {
    display: inline;
  }

  .article-content :global(.code-block[data-copied] .code-block__icon--check) {
    display: inline-block;
  }

  /* --- Mermaid diagrams (pan + zoom canvas) --- */
  .article-content :global(.mermaid-block) {
    @apply border-foreground/10 bg-foreground/5 rounded-xl border;
    position: relative;
    margin: 24px 0;
    overflow: hidden;
  }

  .article-content :global(.mermaid-viewport) {
    height: clamp(260px, 46vh, 460px);
    overflow: hidden;
    cursor: grab;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
  }

  .article-content :global(.mermaid-viewport.is-grabbing) {
    cursor: grabbing;
  }

  /* Transformed by JS (translate + scale); origin at top-left for predictable math. */
  .article-content :global(.mermaid-canvas) {
    transform-origin: 0 0;
    width: max-content;
    will-change: transform;
  }

  /*
   * The article's global `* { font-size: 1rem; line-height: 1.78 }` also hits the
   * SVG label text / foreignObject divs, inflating them past the 13px Mermaid measured
   * the node boxes with — which clips the text. Reset the subtree so its text follows
   * Mermaid's own sizing (measured == rendered).
   */
  .article-content :global(.mermaid-block svg) {
    font-size: 13px;
  }

  .article-content :global(.mermaid-block svg *),
  .article-content :global(.mermaid-block foreignObject *) {
    font-size: inherit;
    line-height: normal;
  }

  .article-content :global(.mermaid-controls) {
    position: absolute;
    top: 10px;
    right: 10px;
    display: flex;
    gap: 4px;
  }

  .article-content :global(.mermaid-ctrl) {
    @apply border-foreground/10 bg-background/70 text-foreground/60 hover:text-foreground hover:border-foreground/25 cursor-pointer rounded-md border transition-colors;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    backdrop-filter: blur(6px);
  }

  .article-content :global(.mermaid-ctrl svg) {
    width: 15px;
    height: 15px;
  }

  /* Line numbers: Shiki wraps every line in <span class="line">. */
  .article-content :global(.code-block > pre code) {
    counter-reset: line;
  }

  .article-content :global(.code-block > pre code .line) {
    counter-increment: line;
  }

  .article-content :global(.code-block > pre code .line)::before {
    @apply text-foreground/25;
    content: counter(line);
    display: inline-block;
    width: 1.6rem;
    margin-right: 1.1rem;
    text-align: right;
    user-select: none;
    -webkit-user-select: none;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 20px 0;
    padding-left: 28px;
  }

  .article-content :global(li) {
    @apply text-foreground/70;
    margin-bottom: 8px;
    padding-left: 6px;
  }

  .article-content :global(ul) {
    list-style: none;
    padding-left: 4px;
  }

  .article-content :global(ul > li) {
    position: relative;
    padding-left: 24px;
  }

  .article-content :global(ul > li)::before {
    @apply text-primary;
    content: "-";
    position: absolute;
    left: 0;
    font-weight: 600;
  }

  .article-content :global(ol) {
    list-style: none;
    counter-reset: item;
    padding-left: 4px;
  }

  .article-content :global(ol > li) {
    position: relative;
    padding-left: 32px;
    counter-increment: item;
  }

  .article-content :global(ol > li)::before {
    @apply text-primary font-mono!;
    content: counter(item) ".";
    position: absolute;
    left: 0;
    font-weight: 600;
  }

  .article-content :global(li > ul),
  .article-content :global(li > ol) {
    margin: 8px 0;
  }

  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 14px;
    line-height: 1.5;
  }

  .article-content :global(th),
  .article-content :global(td) {
    @apply border-foreground/10 border;
    padding: 11px 16px;
    text-align: left;
  }

  .article-content :global(th) {
    @apply text-foreground bg-foreground/5 border-b-foreground/25 font-mono! font-semibold;
    border-bottom-width: 2px;
  }

  .article-content :global(td) {
    @apply text-foreground/70;
  }

  :global(html[data-mode="immersive"]) .article-title {
    @apply font-mono-heading!;
    font-size: clamp(44px, 6vw, 72px);
  }

  :global(html[data-mode="regular"]) .article-title {
    @apply font-mono! font-semibold;
    font-size: clamp(30px, 4vw, 42px);
  }

  .article-content :global(tbody tr:hover) {
    @apply bg-foreground/3;
  }
</style>
