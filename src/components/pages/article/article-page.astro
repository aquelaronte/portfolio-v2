---
import BlogLayout from "@/components/layouts/blog-layout.astro";
import LayoutPicker from "./layout-picker.astro";
import ArticleContent from "./article-content.astro";
import type { Article } from "@/lib/infrastructure/articles/fetch";
import ArticleIndex from "./article-index.astro";
import { render } from "astro:content";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const { headings } = await render(article);
---

<BlogLayout>
  <LayoutPicker />
  <div
    class="article-grid relative z-10 mx-auto grid max-w-295 grid-cols-1 items-start gap-10 px-5 pt-8 pb-24 sm:px-8 lg:grid-cols-[minmax(0px,1fr)_240px] lg:gap-14 lg:pt-13 lg:pb-35"
  >
    <ArticleContent article={article} headings={headings} />
    <ArticleIndex headings={headings} />
  </div>
</BlogLayout>

<style>
  @reference "../../../styles/global.css";

  /* Immersive mode: drop the grid layout and hide the index sidebar. */
  :global(html[data-mode="immersive"]) .article-grid {
    display: block;
  }

  :global(html[data-mode="immersive"]) .article-grid :global(aside) {
    display: none;
  }

  /* Below lg there is no room for the sidebar; the index moves inline (after the
     cover) instead — see article-index.astro. */
  @media (max-width: 1023px) {
    .article-grid :global(aside) {
      display: none;
    }
  }
</style>
