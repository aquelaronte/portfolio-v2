---
import type { MarkdownHeading } from "astro";
import ArticleIndexItem from "./article-index-item.astro";

interface Props {
  headings: MarkdownHeading[];
  /**
   * "sidebar" (default) renders the sticky right-column index used in regular mode.
   * "inline" renders a full-width card meant to sit right after the cover in immersive mode.
   */
  variant?: "sidebar" | "inline";
}

const { headings, variant = "sidebar" } = Astro.props;

// Only surface section headings (skip the page title h1 and very deep ones).
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const minDepth = toc.length ? Math.min(...toc.map((h) => h.depth)) : 2;

const counters: number[] = [];
const items = toc.map((heading) => {
  const tabLevel = heading.depth - minDepth;
  counters.length = tabLevel + 1;
  counters[tabLevel] = (counters[tabLevel] ?? 0) + 1;

  return {
    slug: heading.slug,
    text: heading.text,
    tabLevel,
    label: counters.slice(0, tabLevel + 1).join("."),
  };
});
---

{
  variant === "inline" ? (
    <nav class="article-index-inline">
      <div class="border-foreground/10 bg-foreground/5 rounded-xl border px-5 py-4.5">
        <div class="text-primary mb-3.5 text-xs tracking-widest">&gt; índice</div>

        <div class="index-inline-grid">
          {items.map((item) => (
            <ArticleIndexItem
              href={`#${item.slug}`}
              label={item.label}
              tabLevel={item.tabLevel}
            >
              {item.text}
            </ArticleIndexItem>
          ))}
        </div>
      </div>
    </nav>
  ) : (
    <aside class="sticky top-30">
      <div class="border-foreground/10 bg-foreground/5 flex max-h-[calc(100vh-12rem)] flex-col rounded-xl border px-4.5 py-4">
        <div class="text-primary mb-3.5 shrink-0 text-xs tracking-widest">
          &gt; índice
        </div>

        <div class="index-scroll -mr-2 min-h-0 overflow-y-auto pr-2">
          {items.map((item) => (
            <ArticleIndexItem
              href={`#${item.slug}`}
              label={item.label}
              tabLevel={item.tabLevel}
            >
              {item.text}
            </ArticleIndexItem>
          ))}
        </div>
      </div>
    </aside>
  )
}

<style>
  @reference "../../../styles/global.css";

  /* Inline (immersive) index: hidden by default, revealed only in immersive mode. */
  .article-index-inline {
    display: none;
    margin-bottom: 40px;
  }

  :global(html[data-mode="immersive"]) .article-index-inline {
    display: block;
  }

  /* Full-width vertical list (same as the sidebar, just spanning the content width). */
  .index-inline-grid {
    display: block;
  }

  .index-scroll {
    scrollbar-width: thin;
    scrollbar-color: color-mix(
        in oklab,
        var(--color-foreground) 18%,
        transparent
      )
      transparent;
  }

  .index-scroll::-webkit-scrollbar {
    width: 6px;
  }

  .index-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .index-scroll::-webkit-scrollbar-thumb {
    @apply bg-foreground/15 rounded-full;
  }

  .index-scroll::-webkit-scrollbar-thumb:hover {
    @apply bg-foreground/25;
  }
</style>
