---
import TerminalLine from "../atoms/terminal-line.astro";
import TerminalCursor from "../atoms/terminal-cursor.astro";
import { getLang, useTranslations } from "@/lib/i18n/ui";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

// Locale-independent path (drop any leading /es|/en prefix) so the switch links
// to the same page in the other language, e.g. /en/blog/slug <-> /blog/slug.
const basePath =
  Astro.url.pathname.replace(/^\/(es|en)(?=\/|$)/, "").replace(/^\//, "") ||
  "blog";

const localeLinks = [
  {
    code: "es" as const,
    label: "ES",
    href: getRelativeLocaleUrl("es", basePath),
  },
  {
    code: "en" as const,
    label: "EN",
    href: getRelativeLocaleUrl("en", basePath),
  },
];
---

{
  /* Thin, consistent scrollbars across every scrollable element on blog pages.
    `:global()` makes these rules unscoped, but they only ship where this layout
    is used (blog/*), so the rest of the site is unaffected. Mirrors the style
    originally defined for the article index. */
}
<style is:global>
  @reference "../../styles/global.css";

  .blog-scope :where(*) {
    scrollbar-width: thin;
    scrollbar-color: color-mix(
        in oklab,
        var(--color-foreground) 18%,
        transparent
      )
      transparent;
  }

  .blog-scope :where(*)::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .blog-scope :where(*)::-webkit-scrollbar-track {
    background: transparent;
  }

  .blog-scope :where(*)::-webkit-scrollbar-thumb {
    @apply bg-foreground/15 rounded-full;
  }

  .blog-scope :where(*)::-webkit-scrollbar-thumb:hover {
    @apply bg-foreground/25;
  }

  /* Language switch (in the persisted header). Global so it ships reliably from
     this layout; the active button is driven by the [data-active] attribute,
     which the inline script keeps in sync on every client navigation. */
  .lang-switch__link {
    @apply text-foreground/60 rounded px-1.5 py-1 font-semibold transition-colors;
  }

  .lang-switch__link:hover {
    @apply text-foreground;
  }

  .lang-switch__link[data-active="true"] {
    @apply bg-foreground/10 text-foreground;
  }
</style>

<div
  class="bg-background/80 fixed inset-0 -z-20 backdrop-blur-xl"
  transition:persist
>
</div>
<div
  class="pointer-events-none fixed inset-0 -z-10"
  style="background-image: linear-gradient(to right, color-mix(in oklab, var(--color-foreground) 4%, transparent) 1px, transparent 1px), linear-gradient(to bottom, color-mix(in oklab, var(--color-foreground) 4%, transparent) 1px, transparent 1px); background-size: 44px 44px; mask-image: radial-gradient(ellipse at center, black 40%, transparent 85%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 85%);"
  transition:persist
>
</div>
<header
  class="border-b-foreground/10 bg-background sticky top-0 z-20 flex items-center justify-between gap-4 border-b px-5 py-3.5 font-mono sm:px-6.5"
  transition:persist
>
  <div class="flex items-center gap-2.5 text-sm select-none">
    <span class="flex gap-1.5">
      <span class="size-2.5 cursor-pointer rounded-full bg-[rgb(255,95,87)]"
      ></span>
      <span class="size-2.5 cursor-pointer rounded-full bg-[rgb(254,188,46)]"
      ></span>
      <span class="size-2.5 rounded-full bg-[rgb(40,200,64)]"></span>
    </span>
    <span class="text-foreground/70"> guest </span>
    <span>:</span>
    <span>
      <TerminalLine>
        ~/blog <TerminalCursor />
      </TerminalLine>
    </span>
  </div>
  <div class="flex items-center gap-3">
    <nav
      class="lang-switch border-foreground/10 flex items-center gap-0.5 rounded-md border p-0.5 text-xs"
      aria-label="Language"
    >
      {
        localeLinks.map((locale) => (
          <a
            href={locale.href}
            data-locale-link={locale.code}
            data-active={locale.code === lang}
            class="lang-switch__link"
          >
            {locale.label}
          </a>
        ))
      }
    </nav>
    <a href="/" target="_blank">
      <div
        class="bg-primary cursor-pointer rounded-md border px-2 py-1.5 text-xs text-black"
      >
        {t("header.about")}
      </div>
    </a>
  </div>
</header>

<script>
  import { saveLang } from "@/lib/i18n/language-detect";

  // The <header> uses `transition:persist`, so on client-side navigation it is
  // carried over from the previous page: the language switch would keep a stale
  // active state and stale hrefs (pointing at the previous page's counterpart).
  // Re-derive both from the current URL on every page load.
  function syncLangSwitch() {
    const path = window.location.pathname;
    const isEn = /^\/en(\/|$)/.test(path);
    const base =
      path
        .replace(/^\/(es|en)(?=\/|$)/, "")
        .replace(/^\/+/, "")
        .replace(/\/+$/, "") || "blog";

    document
      .querySelectorAll<HTMLAnchorElement>("[data-locale-link]")
      .forEach((link) => {
        const code = link.dataset.localeLink;
        link.setAttribute("href", code === "en" ? `/en/${base}/` : `/${base}/`);
        link.dataset.active = String(code === (isEn ? "en" : "es"));
      });
  }

  // Persist the language choice whenever the user clicks a locale link so
  // future visits land on their preferred language automatically.
  document.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest<HTMLElement>(
      "[data-locale-link]",
    );
    if (link) saveLang(link.dataset.localeLink as "es" | "en");
  });

  document.addEventListener("astro:page-load", syncLangSwitch);
</script>

<main
  class="blog-scope relative mx-auto max-w-[100vw] px-5 pb-30 font-mono sm:px-8"
>
  <slot />
</main>
