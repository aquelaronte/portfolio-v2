---
import bgVideo from "@/assets/blog/background.webm";
import TerminalLine from "../atoms/terminal-line.astro";
import TerminalCursor from "../atoms/terminal-cursor.astro";
---

{
  /* Thin, consistent scrollbars across every scrollable element on blog pages.
    `:global()` makes these rules unscoped, but they only ship where this layout
    is used (blog/*), so the rest of the site is unaffected. Mirrors the style
    originally defined for the article index. */
}
<style is:global>
  @reference "../../styles/global.css";

  .blog-scope :where(*) {
    scrollbar-width: thin;
    scrollbar-color: color-mix(
        in oklab,
        var(--color-foreground) 18%,
        transparent
      )
      transparent;
  }

  .blog-scope :where(*)::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .blog-scope :where(*)::-webkit-scrollbar-track {
    background: transparent;
  }

  .blog-scope :where(*)::-webkit-scrollbar-thumb {
    @apply bg-foreground/15 rounded-full;
  }

  .blog-scope :where(*)::-webkit-scrollbar-thumb:hover {
    @apply bg-foreground/25;
  }
</style>

<video
  class="fixed inset-0 -z-20 h-full w-full object-cover"
  src={bgVideo}
  autoplay
  loop
  muted
  playsinline
  transition:persist></video>
<div
  class="bg-background/80 fixed inset-0 -z-10 backdrop-blur-xl"
  transition:persist
>
</div>
<header
  class="border-b-foreground/10 bg-background sticky top-0 z-20 flex items-center justify-between gap-4 border-b px-5 py-3.5 font-mono sm:px-6.5"
  transition:persist
>
  <div class="flex items-center gap-2.5 text-sm select-none">
    <span class="flex gap-1.5">
      <span class="size-2.5 cursor-pointer rounded-full bg-[rgb(255,95,87)]"
      ></span>
      <span class="size-2.5 cursor-pointer rounded-full bg-[rgb(254,188,46)]"
      ></span>
      <span class="size-2.5 rounded-full bg-[rgb(40,200,64)]"></span>
    </span>
    <span class="text-foreground/70"> guest </span>
    <span>:</span>
    <span>
      <TerminalLine>
        ~/blog <TerminalCursor />
      </TerminalLine>
    </span>
  </div>
  <div
    class="bg-primary cursor-pointer rounded-md border px-2 py-1.5 text-xs text-black"
  >
    Sobre mi
  </div>
</header>

<main
  class="blog-scope relative mx-auto max-w-[100vw] px-5 pb-30 font-mono sm:px-8"
>
  <slot />
</main>
