---
import "@/styles/global.css";
import { getLang } from "@/lib/i18n/ui";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  class?: string;
  clientRouter?: boolean;
  transitionName?: string;
  /** Root-relative or absolute path used for og:image / twitter:image. */
  image?: string;
  /** Open Graph object type. Use "article" for blog posts. */
  ogType?: "website" | "article";
  /** ISO date — article publish time (adds article:published_time + JSON-LD). */
  publishedTime?: string;
  /** ISO date — last modified time. */
  modifiedTime?: string;
  /** Article tags/keywords. */
  tags?: string[];
  /** Emit ES/EN hreflang alternates (true for bilingual routes, e.g. the blog). */
  bilingual?: boolean;
  /** Set true to keep a page out of the index. */
  noindex?: boolean;
}

const SITE_NAME = "Brahian Arias";
const AUTHOR = "Brahian Arias";
// Social/authoritative profiles for the Person entity (schema.org `sameAs`).
// Add more (LinkedIn, X, etc.) here to strengthen entity recognition.
const AUTHOR_SAMEAS = [
  "https://github.com/aquelaronte",
  "https://www.linkedin.com/in/brahian-arias-rold%C3%A1n-353932269",
];
const DEFAULT_DESCRIPTION =
  "Portfolio and blog of Brahian Arias, Software Engineer focused on backend, cloud infrastructure and artificial intelligence.";

const {
  title,
  class: className,
  description = DEFAULT_DESCRIPTION,
  clientRouter = false,
  image = "/og.png",
  ogType = "website",
  publishedTime,
  modifiedTime,
  tags,
  bilingual = false,
  noindex = false,
} = Astro.props;

const lang = getLang(Astro.currentLocale);

// `Astro.site` comes from `site` in astro.config. Fall back defensively so a
// missing config never crashes the build.
const site = Astro.site ?? new URL("https://arias.systems");
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImageURL = new URL(image, site);

// hreflang alternates: strip the /en prefix to get the locale-independent path,
// then rebuild both locale URLs. Only emitted for bilingual routes.
const basePath = Astro.url.pathname.replace(/^\/en(?=\/|$)/, "") || "/";
const esHref = new URL(basePath, site).href;
const enHref = new URL(`/en${basePath === "/" ? "" : basePath}`, site).href;

const isArticle = ogType === "article";

const jsonLd = isArticle
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      image: ogImageURL.href,
      datePublished: publishedTime,
      dateModified: modifiedTime ?? publishedTime,
      inLanguage: lang,
      mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL.href },
      author: { "@type": "Person", name: AUTHOR, url: site.href },
      publisher: { "@type": "Person", name: AUTHOR, url: site.href },
      ...(tags && tags.length ? { keywords: tags.join(", ") } : {}),
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE_NAME,
      url: site.href,
      inLanguage: lang,
      description,
      author: {
        "@type": "Person",
        name: AUTHOR,
        url: site.href,
        jobTitle: "Software Engineer",
        sameAs: AUTHOR_SAMEAS,
      },
    };

// Breadcrumb trail (Home → Blog → Article) — only meaningful on articles.
const blogHref = new URL(lang === "en" ? "/en/blog/" : "/blog/", site).href;
const breadcrumbLd = isArticle
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: lang === "en" ? "Home" : "Inicio",
          item: site.href,
        },
        { "@type": "ListItem", position: 2, name: "Blog", item: blogHref },
        {
          "@type": "ListItem",
          position: 3,
          name: title,
          item: canonicalURL.href,
        },
      ],
    }
  : null;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      const applyReadingMode = () => {
        document.documentElement.dataset.mode =
          localStorage.getItem("reading-mode") || "regular";
      };

      applyReadingMode();
      document.addEventListener("astro:after-swap", applyReadingMode);
    </script>

    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-geist-mono" preload />
    <Font cssVariable="--font-jacquard" preload />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={AUTHOR} />
    <meta
      name="robots"
      content={noindex
        ? "noindex, nofollow"
        : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />

    <link rel="canonical" href={canonicalURL.href} />

    {
      /* hreflang alternates so crawlers link the ES/EN versions of a page. */
      bilingual && (
        <>
          <link rel="alternate" hreflang="es" href={esHref} />
          <link rel="alternate" hreflang="en" href={enHref} />
          <link rel="alternate" hreflang="x-default" href={esHref} />
        </>
      )
    }

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "es_ES"} />
    {
      isArticle && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      isArticle && (modifiedTime || publishedTime) && (
        <meta
          property="article:modified_time"
          content={modifiedTime ?? publishedTime}
        />
      )
    }
    {isArticle && <meta property="article:author" content={AUTHOR} />}
    {
      isArticle &&
        tags?.map((tag) => <meta property="article:tag" content={tag} />)
    }

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    {/* Structured data */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {
      breadcrumbLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbLd)}
        />
      )
    }

    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {clientRouter && <ClientRouter />}
  </head>
  <body class={className}>
    <slot />
  </body>
</html>
